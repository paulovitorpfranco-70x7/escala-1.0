{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/App.jsx",
    "src/main.jsx",
    "src/API/**/*",
    "src/components/**/*",
    "src/lib/**/*",
    "src/pages/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
